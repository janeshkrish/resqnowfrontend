# API
VITE_API_URL=https://your-backend.example.com

# Maps / payments
VITE_GOOGLE_MAPS_API_KEY=your-public-google-maps-key
VITE_RAZORPAY_KEY_ID=rzp_test_placeholder
VITE_PAYMENTS_DISABLED=false

# Firebase public client config
VITE_FIREBASE_API_KEY=your-public-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:replace-me
VITE_FIREBASE_VAPID_KEY=your-public-web-push-vapid-key
